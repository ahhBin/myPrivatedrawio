          <mxGeometry height="56" width="110" x="80" y="492" as="geometry" />
        </mxCell>
        <mxCell id="13" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f2f2f2;strokeColor=#595959;fontColor=#222222;fontSize=14;fontStyle=1;fontFamily=Microsoft YaHei;align=center;verticalAlign=middle;" value="研究内容二" vertex="1">
          <mxGeometry height="56" width="110" x="80" y="837" as="geometry" />
        </mxCell>
        <mxCell id="20" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#666666;fontColor=#222222;fontSize=14;fontFamily=Microsoft YaHei;align=left;verticalAlign=middle;spacing=10;" value="本文以多模态大模型结合 LoRA 的联邦高效微调系统为研究对象，构建由服务器和多个客户端组成的训练框架。客户端仅在本地私有数据上训练 LoRA 模块，服务器负责接收各客户端上传的参数更新并完成全局模型迭代。" vertex="1">
          <mxGeometry height="90" width="1260" x="240" y="90" as="geometry" />
        </mxCell>
        <mxCell id="21" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#666666;fontColor=#222222;fontSize=14;fontFamily=Microsoft YaHei;align=left;verticalAlign=middle;spacing=10;" value="联邦高效微调中的核心困难在于客户端数据分布与承担的任务具有显著异质性。随机选择客户端难以保证每轮训练的数据覆盖能力与任务覆盖能力，进而影响全局模型性能。因此，本文将研究重点聚焦于面向异质场景的客户端选择机制设计。" vertex="1">
          <mxGeometry height="105" width="1260" x="240" y="215" as="geometry" />
        </mxCell>
