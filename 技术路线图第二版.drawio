        <mxCell id="1" parent="0" />
        <mxCell id="3" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#b85450;fontSize=14;" value="研究问题&lt;br&gt;多模态联邦环境存在数据分布异质性与任务异质性，随机客户端选择难以兼顾代表性与多样性；同时通信与计算资源受限，无法在每轮让全部客户端参与训练。" vertex="1">
          <mxGeometry height="90" width="880" x="360" y="62" as="geometry" />
        </mxCell>
        <mxCell id="4" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#d6b656;fontSize=14;fontStyle=1;" value="统一研究框架&lt;br&gt;以联邦学习为协同训练范式，以多模态大模型为任务载体，以 LoRA 为参数高效微调方式，在隐私保护约束下研究客户端选择机制。" vertex="1">
          <mxGeometry height="80" width="760" x="420" y="199" as="geometry" />
        </mxCell>
        <mxCell id="5" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#82b366;fontSize=14;fontStyle=1;" value="研究内容一&lt;br&gt;面向单模态数据的客户端选择" vertex="1">
