        <mxCell id="6" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673a6;fontSize=13;" value="技术方法&lt;br&gt;利用客户端本地数据表征刻画数据分布特征，构建客户端相似性核矩阵，并结合 k-DPP 进行多样性驱动采样。" vertex="1">
          <mxGeometry height="100" width="380" x="352" y="443" as="geometry" />
